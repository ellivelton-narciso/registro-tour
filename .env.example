# Copiar para .env na raiz do registro-tour (compose de produção na VPS Subway)
# Backend: copiar também backend/.env (DB_*, JWT_SECRET, etc.)
# EV counter: ~/Subway-Ev-Counter/.env com DATABASE_URL

# --- Domínios públicos (DNS A → VPS vps-aba40034) ---
# Copie os ServerName dos vhosts Apache atuais (sites-available):
#   ds-front*.conf        → DOMAIN_FRONTEND
#   api-registro.conf     → DOMAIN_API
#   ev-counter*.conf      → DOMAIN_EV_COUNTER
DOMAIN_FRONTEND=ds.subway.vako.pt
DOMAIN_API=api-registro.subway.vako.pt
DOMAIN_EV_COUNTER=ev-counter.subway.vako.pt

# Pasta do certificado em /etc/letsencrypt/live/ (geralmente o primeiro -d do certbot)
SSL_CERT_DIR=ds.subway.vako.pt

# URL da API usada no build do frontend React (HTTPS, domínio DOMAIN_API)
VITE_API_URL=https://api-registro.subway.vako.pt

# Upstream interno do nginx para o container frontend (default: frontend:80)
FRONTEND_UPSTREAM=frontend:80

# Build do ev_counter (pasta irmã na VPS: ~/Subway-Ev-Counter)
# Monorepo local: EV_COUNTER_BUILD_CONTEXT=../ev_counter
EV_COUNTER_BUILD_CONTEXT=../Subway-Ev-Counter
EV_COUNTER_ENV_FILE=../Subway-Ev-Counter/.env

# Portas do gateway (80/443). Esta VPS é separada do Hub API — sem conflito de portas.
HTTP_PORT=80
HTTPS_PORT=443
